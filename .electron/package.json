{
  "name": "lab",
  "productName": "Jason Tsang's Lab",
  "description": "Jason Tsang's Lab",
  "version": "1.0.0",
  "author": "Jason Tsang",
  "main": "src/index.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint src --color"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "packageManager": "npm",
        "name": "lab",
        "icon": "src/app.ico",
        "extraResource": [
          "../dist"
        ],
        "appCopyright": "Copyright(C)2019 Jason Tsang",
        "win32metadata": {
          "CompanyName": "Jason Tsang",
          "ProductName": "Jason Tsang's Lab"
        }
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "lab",
            "setupIcon": "src/app.ico",
            "setupExe": "lab_1.0.0_x64.exe",
            "loadingGif": "src/loading.gif"
          }
        }
      ]
    }
  },
  "dependencies": {
    "axios": "^0.19.0",
    "electron-squirrel-startup": "^1.0.0",
    "electron-store": "^5.1.0",
    "fs-extra": "^8.1.0",
    "is-elevated": "^3.0.0",
    "log4js": "^6.1.0",
    "mkdirp": "^0.5.1",
    "multi-write-stream": "^2.0.1",
    "require-from-memory": "^1.0.2",
    "rimraf": "^3.0.0",
    "rxjs": "^6.5.3"
  },
  "devDependencies": {
    "@electron-forge/cli": "6.0.0-beta.47",
    "@electron-forge/maker-squirrel": "6.0.0-beta.47",
    "electron": "7.1.7",
    "electron-winstaller": "4.0.0"
  }
}
